generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model GenerationRecord {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  title            String
  inputPrompt      String
  diagramType      String
  presetId         String
  provider         String
  diagramJson      String
  generationPrompt String
  status           String   @default("generated")
}
